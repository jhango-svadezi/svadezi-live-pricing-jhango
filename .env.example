# Copy to .env for local runs (never commit .env). In GitHub these are repo Secrets.
SHOPIFY_STORE=svadezi.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ACTIVE PROVIDER = "rapidapi_india" (config.json). Real Indian RETAIL gold/silver
# rates (pre-GST) from RapidAPI "Gold Silver Rates India". ONE call/run returns
# both metals. City is set by "rate_city" in config.json (default: mumbai).
RAPIDAPI_KEY=7ef4xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# RAPIDAPI_CITY=mumbai   # optional override; otherwise config.json rate_city is used

# Fallback provider (metals.dev, global spot) — used automatically only if RapidAPI fails.
METALS_API_KEY=AZ3xxxxxxxxxxxxxxxxxxxxxxxxxxx
